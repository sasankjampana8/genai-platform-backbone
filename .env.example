AWS_REGION=ap-south-1

RAW_BUCKET=rag-agent-documents-sasank

USER_TABLE=cloudrag_users
DOCUMENT_TABLE=cloudrag_documents
PROCESS_JOB_TABLE=cloudrag_process_jobs
CHAT_TABLE=cloudrag_chats
MESSAGE_TABLE=cloudrag_messages
MEMORY_TABLE=cloudrag_memory
PROCESS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/your-account-id/cloudrag-processing-queue

COGNITO_USER_POOL_ID=your-cognito-user-pool-id
COGNITO_CLIENT_ID=your-cognito-app-client-id
AUTH_DISABLED=true
LOCAL_USER_ID=user_123

UPLOAD_EXPIRY_SECONDS=900
MAX_FILES=10
MAX_FILE_SIZE_BYTES=10485760

OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4.1-mini

PG_HOST=your-postgres-host
PG_PORT=5432
PG_DATABASE=cloudragdb
PG_USER=postgres
PG_PASSWORD=your-password

CHUNK_SIZE=800
CHUNK_OVERLAP=120
EMBEDDING_BATCH_SIZE=50
DEFAULT_TOP_K=5
DEFAULT_SIMILARITY_THRESHOLD=0.0
